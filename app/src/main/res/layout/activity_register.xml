<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="რეგისტრაცია"
        android:gravity="center"
        android:lineSpacingExtra="20dp"
        android:textSize="40dp"
        android:textColor="@color/gold"
        android:textStyle="bold"
        android:fontFamily="@font/googlesans"
        android:layout_marginTop="50dp"
        />
<!--შექმენი ანგარიში რომ შეძლო სხვებთან მიმოწერა-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seqmeni angariSi rom SeZlo sxvebTan mimowera"
        android:gravity="center"
        android:lineSpacingExtra="0dp"
        android:textSize="20dp"
        android:textColor="@color/white"
        android:paddingLeft="20dp"
        android:fontFamily="@font/migdebuli"
        android:layout_marginTop="5dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp">

        <EditText
            android:id="@+id/etname"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="სახელი"
            android:fontFamily="@font/googlesans"
            android:textColor="@color/gold"
            android:textColorHint="@color/gold"
            android:background="@drawable/eddittext_bg"/>

        <EditText
            android:id="@+id/etsurname"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="გვარი"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/googlesans"
            android:textColor="@color/gold"
            android:textColorHint="@color/gold"
            android:background="@drawable/eddittext_bg"/>


        <EditText
        android:id="@+id/etemail"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="ელფოსტა"
        android:inputType="textEmailAddress"
        android:layout_marginTop="12dp"
            android:fontFamily="@font/googlesans"
            android:textColor="@color/gold"
            android:textColorHint="@color/gold"
            android:background="@drawable/eddittext_bg"/>

    <EditText
        android:id="@+id/etpassword"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="პაროლი"
        android:inputType="textPassword"
        android:layout_marginTop="12dp"
        android:textColor="@color/gold"
        android:textColorHint="@color/gold"
        android:fontFamily="@font/googlesans"
        android:background="@drawable/eddittext_bg"
        />

        <EditText
            android:id="@+id/etpassword2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="გაიმეორეთ პაროლი"
            android:inputType="textPassword"
            android:layout_marginTop="12dp"
            android:textColor="@color/gold"
            android:textColorHint="@color/gold"
            android:fontFamily="@font/googlesans"
            android:background="@drawable/eddittext_bg"/>



        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnregister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:text="რეგისტრაცია"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            android:background="@drawable/logbtn"
            android:fontFamily="@font/googlesans"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="უკვე გაქვს ანგარიში?"
            android:gravity="center"
            android:textColor="@color/gold"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            android:id="@+id/oldacc"
            android:textSize="16sp"
            android:fontFamily="@font/googlesans"/>
    </LinearLayout>
</LinearLayout>
