<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.FirstActivity"
    android:orientation="vertical"
    android:background="@color/dark">

    <ImageView
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="center"
        android:src="@drawable/cclogo"
        android:layout_marginTop="70dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chatplikaciis Aplikacia"
        android:gravity="center"
        android:lineSpacingExtra="5dp"
        android:textSize="40dp"
        android:textColor="@color/gold"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginTop="-10dp"/>

    <!--უბრალო მიმოწერის აპლიკაცია \n დარეგისტრირდი თუ არ გაქვს ანგარიში-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ubralo mimoweris aplikacia \n daregistrirdi Tu ar gaqvs angariSi"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:textSize="20dp"
        android:textColor="@color/white"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/migdebuli"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp"
       >


        <com.google.android.material.button.MaterialButton
            android:id="@+id/logbtn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="შესვლა"
            android:background="@drawable/logbtn"
            app:backgroundTint="@null"
            android:textColor="@color/dark"
            android:textStyle="bold"
            android:textSize="16sp"
            android:fontFamily="@font/gugs"/>



        <com.google.android.material.button.MaterialButton
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="რეგისტრაცია"
            android:background="@drawable/regbtn"
            android:layout_marginStart="5dp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            android:textColor="@color/gold"
            android:id="@+id/regbtn"
            android:textSize="16dp"
            android:fontFamily="@font/gugs"
            />

    </LinearLayout>

</LinearLayout>